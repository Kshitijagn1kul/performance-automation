# Common
ENVIRONMENT=staging
TEST_TYPE=smoke
VUS=1
DURATION=2m
TARGET_VUS=300

# Base URLs
# Use these to override default staging and production URLs
STAGING_BASE_URL=https://qa.example.com
PROD_BASE_URL=https://prod.example.com
DEV_BASE_URL=http://localhost:3000

# Generic fallback credentials
API_KEY=
API_SECRET=

# Environment-specific credentials
DEV_API_KEY=
DEV_API_SECRET=
STAGING_API_KEY=
STAGING_API_SECRET=
PROD_API_KEY=
PROD_API_SECRET=

# SLA overrides
SLA_HTTP_REQ_DURATION_P95_MS=2000
SLA_HTTP_REQ_DURATION_P99_MS=5000
SLA_WORKFLOW_DURATION_P95_MS=10000
SLA_SEARCH_DURATION_P95_MS=2500
SLA_BULK_DURATION_P95_MS=15000
SLA_ERROR_RATE=0.01
SLA_BUSINESS_FAILURE_RATE=0.02
SLA_SERVER_ERROR_RATE=0.001

# Prometheus Remote Write
# Example: https://prometheus.example.com/api/v1/write
PROM_REMOTE_WRITE_URL=

# Experimental k6 remote write server URL for local testing
K6_PROMETHEUS_RW_SERVER_URL=

# Grafana local observability credentials (optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Safety switch. Keep false unless mutation APIs have dedicated test data.
INCLUDE_MUTATIONS=false
